# Copy to `.env` ON THE SERVER and fill in real values. Never commit the real .env.

# ---- App ----
APP_NAME=PDF Converter API
APP_VERSION=1.0.0
DEBUG=false
MAX_FILE_SIZE_MB=50

# Your public site(s). Use https and your real domain.
ALLOWED_ORIGINS=https://yourdomain.com

# ---- Postgres ----
# Pick a strong password. Used by both the postgres container and the app URLs below.
POSTGRES_USER=pdfuser
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=pdfconverter

# ---- Database URLs (host = compose service name "postgres") ----
DATABASE_URL=postgresql+asyncpg://pdfuser:CHANGE_ME_strong_password@postgres:5432/pdfconverter
DATABASE_SYNC_URL=postgresql+psycopg2://pdfuser:CHANGE_ME_strong_password@postgres:5432/pdfconverter

# ---- Redis (host = compose service name "redis") ----
REDIS_URL=redis://redis:6379/0
