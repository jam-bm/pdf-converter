APP_NAME=PDF Converter API
APP_VERSION=1.0.0
DEBUG=false

# File size limit in MB
MAX_FILE_SIZE_MB=50

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# PostgreSQL — use docker-compose service name "postgres" inside containers
DATABASE_URL=postgresql+asyncpg://pdfuser:pdfpassword@postgres:5432/pdfconverter
DATABASE_SYNC_URL=postgresql+psycopg2://pdfuser:pdfpassword@postgres:5432/pdfconverter

# Redis — use docker-compose service name "redis" inside containers
REDIS_URL=redis://redis:6379/0
